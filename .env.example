# =============================================================================
# Redshift OpenFlow Multi-Mode Replication — Environment Configuration
# cp .env.example .env  then fill in your values
# Lines marked REQUIRED must be set before running any script.
# Lines marked AUTO are populated by 01_aws_redshift.sh output.
# Lines marked DEFAULT are fine to leave unchanged.
# =============================================================================

# ─────────────────────────────────────────────
# Replication Mode
# ─────────────────────────────────────────────

# REQUIRED  Choose your replication strategy:
#
#   gold_mirror  Full table extract on a schedule. No watermark column required.
#                Truncates the Snowflake target table before each load.
#                Best for curated gold-layer tables that are already clean and small.
#                No SCD2 or version history. Target: RAW schema only.
#
#   cdc          Incremental extract using a watermark column (default: updated_at).
#                Appends only new or changed rows since the last run.
#                Requires updated_at (or equivalent) on every source table.
#                No version history. Target: RAW schema only.
#
#   scd2         Same as cdc, plus SCD Type 2 history tracking via Snowflake Dynamic Tables.
#                Every change creates a new versioned row in DIM schema.
#                Requires updated_at on every source table.
#                Target: RAW schema (raw landing) + DIM schema (versioned history).
REPLICATION_MODE=scd2

# ─────────────────────────────────────────────
# AWS
# ─────────────────────────────────────────────

# REQUIRED  AWS region where Redshift will be deployed
AWS_REGION=us-west-2

# REQUIRED  AWS CLI profile name from ~/.aws/credentials with Redshift/EC2/VPC permissions
AWS_PROFILE=your-aws-profile-name

# ─────────────────────────────────────────────
# Redshift Serverless
# ─────────────────────────────────────────────

# DEFAULT  Name for the Redshift Serverless namespace (logical container for databases)
REDSHIFT_NAMESPACE=openflow-demo-ns

# DEFAULT  Name for the Redshift Serverless workgroup (compute endpoint)
REDSHIFT_WORKGROUP=openflow-demo-wg

# DEFAULT  Database name inside Redshift
REDSHIFT_DB=demo

# REQUIRED  Redshift admin username (created during namespace setup)
REDSHIFT_ADMIN_USER=admin

# REQUIRED  Redshift admin password — no special characters (!, @, #) to avoid JDBC escaping issues
REDSHIFT_ADMIN_PASSWORD=your-redshift-password

# DEFAULT  Redshift schema to replicate from
REDSHIFT_SCHEMA=sales

# ─────────────────────────────────────────────
# AWS Networking — populated by 01_aws_redshift.sh
# ─────────────────────────────────────────────

# AUTO  NLB DNS name output by 01_aws_redshift.sh — copy here after running that script
# Also paste this value into setup/02_snowflake_networking.sql VALUE_LIST
NLB_DNS=your-nlb-name.elb.us-west-2.amazonaws.com

# DEFAULT  Port Redshift Serverless listens on
NLB_PORT=5439

# ─────────────────────────────────────────────
# Snowflake
# ─────────────────────────────────────────────

# REQUIRED  Snowflake connection name from ~/.snowflake/connections.toml (used by tests)
SNOWFLAKE_CONNECTION_NAME=your-connection-name

# REQUIRED  Snowflake account identifier (format: ORG-ACCOUNT or legacy ACCOUNT.REGION)
SF_ACCOUNT=your-snowflake-account

# DEFAULT  Database that will be created to hold replicated data
SF_DATABASE=REDSHIFT_DEMO

# DEFAULT  Schema for the initial Snowpipe Streaming landing table (PutSnowpipeStreaming default)
SF_SCHEMA_LANDING=SALES

# DEFAULT  Schema for scaled multi-table RAW landing tables
SF_SCHEMA_RAW=RAW

# DEFAULT  Schema for SCD2 Dynamic Tables (scd2 mode only)
SF_SCHEMA_DIM=DIM

# REQUIRED  Warehouse to use for Dynamic Table refreshes and query execution
SF_WAREHOUSE=your-warehouse-name

# DEFAULT  Role to use when running setup SQL (must be ACCOUNTADMIN or have equivalent privileges)
SF_ROLE=ACCOUNTADMIN

# REQUIRED  Role assigned to the OpenFlow runtime — found in Snowsight > OpenFlow > Runtime > Details
SF_RUNTIME_ROLE=OPENFLOW_RUNTIME_ROLE_MYSQL

# DEFAULT  Name for the External Access Integration that allows OpenFlow to reach Redshift
SF_EAI_NAME=REDSHIFT_OPENFLOW_EAI

# DEFAULT  Database, schema, and name for the Network Rule (can reuse existing admin database)
SF_NETWORK_RULE_DB=ADMIN_DB
SF_NETWORK_RULE_SCHEMA=NETWORK_RULES
SF_NETWORK_RULE_NAME=REDSHIFT_NR

# ─────────────────────────────────────────────
# OpenFlow / NiFi
# ─────────────────────────────────────────────

# REQUIRED  OpenFlow deployment hostname — found in Snowsight > OpenFlow > your deployment
# Format: of--<account-identifier>.snowflakecomputing.app
OPENFLOW_HOST=of--your-account.snowflakecomputing.app

# REQUIRED  Runtime name as shown in OpenFlow Control Plane
# Note: may have a typo from creation — verify exact name in UI
OPENFLOW_RUNTIME=your-runtime-name

# AUTO  Full NiFi API URL — derived from OPENFLOW_HOST and OPENFLOW_RUNTIME above
# Note: this variable uses shell expansion syntax; build_flow.py derives it from the two vars above
NIFI_BASE_URL=https://${OPENFLOW_HOST}/${OPENFLOW_RUNTIME}/nifi-api

# REQUIRED  NiFi Bearer Token for API authentication
# Get from: nipyapi profile OR copy from browser DevTools when logged into OpenFlow canvas
NIFI_PAT=

# REQUIRED  nipyapi profile name from ~/.nipyapi/profiles.yml — used by tests
NIPYAPI_PROFILE=your-nipyapi-profile-name

# ─────────────────────────────────────────────
# JDBC Driver
# ─────────────────────────────────────────────

# REQUIRED  Directory where Redshift JDBC JARs are extracted (from drivers/redshift-jdbc42-*.zip)
# Run: mkdir -p /tmp/redshift-jdbc && cd /tmp/redshift-jdbc && unzip /path/to/drivers/*.zip
JDBC_JAR_DIR=/tmp/redshift-jdbc

# ─────────────────────────────────────────────
# Flow Configuration — applies to all modes
# ─────────────────────────────────────────────

# DEFAULT  Redshift schema pattern for ListDatabaseTables (% = wildcard, matches all schemas)
REDSHIFT_SCHEMA_PATTERN=sales

# DEFAULT  Table name pattern for ListDatabaseTables (% = all tables in the schema)
REDSHIFT_TABLE_PATTERN=%

# DEFAULT  Max JDBC connections in the DBCP pool
#          Must be >= ESQL_CONCURRENT_TASKS
#          For 1500 tables: 25 is sufficient since only ESQL_CONCURRENT_TASKS run simultaneously
DBCP_MAX_CONNECTIONS=25

# DEFAULT  Concurrent threads for ExecuteSQL (parallel table reads from Redshift)
#          For 1500 tables: 10 is a safe starting point; increase if Redshift RPU allows
ESQL_CONCURRENT_TASKS=10

# DEFAULT  Concurrent threads for PutSnowpipeStreaming (parallel writes to Snowflake)
PSS_CONCURRENT_TASKS=5

# DEFAULT  NiFi queue object threshold before back-pressure activates
#          Increase for high-table-count deployments to prevent premature back-pressure
NIFI_QUEUE_OBJECT_THRESHOLD=50000

# DEFAULT  NiFi queue size threshold before back-pressure activates
NIFI_QUEUE_SIZE_THRESHOLD=2 GB

# ─────────────────────────────────────────────
# Flow Configuration — cdc and scd2 modes only
# ─────────────────────────────────────────────

# DEFAULT  Column used for watermark-based incremental sync
#          Must exist on every source table — tables without this column will produce 0 rows
#          Leave blank or remove if using gold_mirror mode (no watermark needed)
WATERMARK_COLUMN=updated_at

# DEFAULT  Number of rows per paginated query from Redshift
#          For cdc/scd2: 10000 is a good default for incremental loads
#          For gold_mirror: set to 0 (single query per table, no pagination)
GTF_PARTITION_SIZE=10000

# ─────────────────────────────────────────────
# Flow Configuration — gold_mirror mode only
# ─────────────────────────────────────────────

# DEFAULT  Whether to truncate each Snowflake target table before loading
#          true  = clean full reload every cycle (safe, no duplicates, higher cost)
#          false = append only — only use if source never reuses primary keys
TRUNCATE_BEFORE_LOAD=true

# ─────────────────────────────────────────────
# Flow Configuration — scd2 mode only
# ─────────────────────────────────────────────

# DEFAULT  How fresh SCD2 Dynamic Tables should be
#          Lower values = more frequent warehouse refreshes = higher cost
#          '5 minutes' is a good balance for demo/dev; use '1 hour' for cost-sensitive production
SCD2_TARGET_LAG=5 minutes

# DEFAULT  Number of SCD2 Dynamic Tables to create per batch
#          Batching avoids overwhelming the warehouse with 1500 simultaneous ON_CREATE refreshes
SCD2_CREATE_BATCH_SIZE=50


# ─────────────────────────────────────────────
# AWS
# ─────────────────────────────────────────────

# REQUIRED  AWS region where Redshift will be deployed
AWS_REGION=us-west-2

# REQUIRED  AWS CLI profile name from ~/.aws/credentials with Redshift/EC2/VPC permissions
AWS_PROFILE=your-aws-profile-name

# ─────────────────────────────────────────────
# Redshift Serverless
# ─────────────────────────────────────────────

# DEFAULT  Name for the Redshift Serverless namespace (logical container for databases)
REDSHIFT_NAMESPACE=openflow-demo-ns

# DEFAULT  Name for the Redshift Serverless workgroup (compute endpoint)
REDSHIFT_WORKGROUP=openflow-demo-wg

# DEFAULT  Database name inside Redshift
REDSHIFT_DB=demo

# REQUIRED  Redshift admin username (created during namespace setup)
REDSHIFT_ADMIN_USER=admin

# REQUIRED  Redshift admin password — no special characters (!, @, #) to avoid JDBC escaping issues
REDSHIFT_ADMIN_PASSWORD=your-redshift-password

# DEFAULT  Redshift schema to replicate from
REDSHIFT_SCHEMA=sales

# ─────────────────────────────────────────────
# AWS Networking — populated by 01_aws_redshift.sh
# ─────────────────────────────────────────────

# AUTO  NLB DNS name output by 01_aws_redshift.sh — copy here after running that script
# Also paste this value into setup/02_snowflake_networking.sql VALUE_LIST
NLB_DNS=your-nlb-name.elb.us-west-2.amazonaws.com

# DEFAULT  Port Redshift Serverless listens on
NLB_PORT=5439

# ─────────────────────────────────────────────
# Snowflake
# ─────────────────────────────────────────────

# REQUIRED  Snowflake connection name from ~/.snowflake/connections.toml (used by tests)
SNOWFLAKE_CONNECTION_NAME=your-connection-name

# REQUIRED  Snowflake account identifier (format: ORG-ACCOUNT or legacy ACCOUNT.REGION)
SF_ACCOUNT=your-snowflake-account

# DEFAULT  Database that will be created to hold replicated data
SF_DATABASE=REDSHIFT_DEMO

# DEFAULT  Schema for the initial Snowpipe Streaming landing table (PutSnowpipeStreaming default)
SF_SCHEMA_LANDING=SALES

# DEFAULT  Schema for scaled multi-table RAW landing tables
SF_SCHEMA_RAW=RAW

# DEFAULT  Schema for SCD2 Dynamic Tables
SF_SCHEMA_DIM=DIM

# REQUIRED  Warehouse to use for Dynamic Table refreshes and query execution
SF_WAREHOUSE=your-warehouse-name

# DEFAULT  Role to use when running setup SQL (must be ACCOUNTADMIN or have equivalent privileges)
SF_ROLE=ACCOUNTADMIN

# REQUIRED  Role assigned to the OpenFlow runtime — found in Snowsight > OpenFlow > Runtime > Details
SF_RUNTIME_ROLE=OPENFLOW_RUNTIME_ROLE_MYSQL

# DEFAULT  Name for the External Access Integration that allows OpenFlow to reach Redshift
SF_EAI_NAME=REDSHIFT_OPENFLOW_EAI

# DEFAULT  Database, schema, and name for the Network Rule (can reuse existing admin database)
SF_NETWORK_RULE_DB=ADMIN_DB
SF_NETWORK_RULE_SCHEMA=NETWORK_RULES
SF_NETWORK_RULE_NAME=REDSHIFT_NR

# ─────────────────────────────────────────────
# OpenFlow / NiFi
# ─────────────────────────────────────────────

# REQUIRED  OpenFlow deployment hostname — found in Snowsight > OpenFlow > your deployment
# Format: of--<account-identifier>.snowflakecomputing.app
OPENFLOW_HOST=of--your-account.snowflakecomputing.app

# REQUIRED  Runtime name as shown in OpenFlow Control Plane
# Note: may have a typo from creation — verify exact name in UI
OPENFLOW_RUNTIME=your-runtime-name

# AUTO  Full NiFi API URL — derived from OPENFLOW_HOST and OPENFLOW_RUNTIME above
NIFI_BASE_URL=https://${OPENFLOW_HOST}/${OPENFLOW_RUNTIME}/nifi-api

# REQUIRED  NiFi Bearer Token for API authentication
# Get from: nipyapi profile OR copy from browser DevTools when logged into OpenFlow canvas
NIFI_PAT=

# REQUIRED  nipyapi profile name from ~/.nipyapi/profiles.yml — used by tests
NIPYAPI_PROFILE=your-nipyapi-profile-name

# ─────────────────────────────────────────────
# JDBC Driver
# ─────────────────────────────────────────────

# REQUIRED  Directory where Redshift JDBC JARs are extracted (from drivers/redshift-jdbc42-*.zip)
# Run: mkdir -p /tmp/redshift-jdbc && cd /tmp/redshift-jdbc && unzip /path/to/drivers/*.zip
JDBC_JAR_DIR=/tmp/redshift-jdbc

# ─────────────────────────────────────────────
# Flow Configuration
# ─────────────────────────────────────────────

# DEFAULT  Redshift schema pattern for ListDatabaseTables (% = wildcard)
REDSHIFT_SCHEMA_PATTERN=sales

# DEFAULT  Table name pattern for ListDatabaseTables (% = all tables)
REDSHIFT_TABLE_PATTERN=%

# DEFAULT  Column used for watermark-based incremental sync — must exist on all source tables
WATERMARK_COLUMN=updated_at

# DEFAULT  Max JDBC connections in the DBCP pool — must be >= ESQL_CONCURRENT_TASKS
DBCP_MAX_CONNECTIONS=25

# DEFAULT  Concurrent threads for ExecuteSQL (parallel table reads)
ESQL_CONCURRENT_TASKS=10

# DEFAULT  Concurrent threads for PutSnowpipeStreaming (parallel Snowflake writes)
PSS_CONCURRENT_TASKS=5
